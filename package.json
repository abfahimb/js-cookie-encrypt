{
    "name": "js-cookie-encrypt",
    "version": "1.1.1",
    "description": "The only actively maintained client-side encrypted cookie library. AES-GCM 256-bit encryption via native SubtleCrypto, zero dependencies, TypeScript generics, key rotation, deep path API, and SSR support (Next.js/Nuxt/Remix).",
    "main": "dist/js-cookie-encrypt.min.js",
    "types": "dist/js-cookie-encrypt.d.ts",
    "unpkg": "dist/js-cookie-encrypt.min.js",
    "jsdelivr": "dist/js-cookie-encrypt.min.js",
    "files": [
        "dist/js-cookie-encrypt.min.js",
        "dist/js-cookie-encrypt.d.ts",
        "LICENSE",
        "README.md"
    ],
    "keywords": [
        "cookie",
        "cookies",
        "encrypt",
        "encryption",
        "encrypted-cookie",
        "cookie-encrypt",
        "aes-gcm",
        "aes",
        "secure-cookie",
        "js-cookie",
        "js-cookie-encrypt",
        "browser",
        "client-side",
        "typescript",
        "nextjs",
        "nuxt",
        "ssr",
        "key-rotation",
        "webcrypto",
        "subtle-crypto",
        "zero-dependency",
        "cookie-storage",
        "cookie-manager",
        "privacy"
    ],
    "homepage": "https://github.com/abfahimb/js-cookie-encrypt#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/abfahimb/js-cookie-encrypt.git"
    },
    "author": "Abdullah Al Fahim",
    "license": "MIT",
    "scripts": {
        "build": "tsc && terser dist/js-cookie-encrypt.js -o dist/js-cookie-encrypt.min.js --compress --mangle --comments '/^!/'",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "terser": "^5.0.0",
        "typescript": "^4.9.5"
    },
    "dependencies": {}
}
